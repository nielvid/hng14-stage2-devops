# Copy this file to .env and fill in values before running docker compose.
# .env is gitignored and must never be committed.

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis

# ── API ───────────────────────────────────────────────────────────────────────
# URL the frontend container uses to reach the API (use service name, not localhost)
API_URL=http://api:8000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Host port to expose the frontend on
FRONTEND_PORT=3000

# ── Resource limits ───────────────────────────────────────────────────────────
REDIS_CPU_LIMIT=0.25
REDIS_MEM_LIMIT=128m

API_CPU_LIMIT=0.50
API_MEM_LIMIT=256m

WORKER_CPU_LIMIT=0.50
WORKER_MEM_LIMIT=256m

FRONTEND_CPU_LIMIT=0.50
FRONTEND_MEM_LIMIT=256m
