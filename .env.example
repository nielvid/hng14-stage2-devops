# Copy this file to .env and fill in values before running docker compose.

# ── Redis ────────────────────────────────────────────────────────────────────
# Hostname of the Redis service (matches the Compose service name)
REDIS_HOST=<required: redis>



# ── Frontend ─────────────────────────────────────────────────────────────────
# URL the frontend container uses to reach the API (use service name, not localhost)
API_URL=<required: http://api:8000> 

# Host port to expose the frontend on
APP_PORT=<optional: 3000>

# ── Resource limits (optional — defaults shown) ───────────────────────────────
REDIS_CPU_LIMIT=<optional: 0.25>
REDIS_MEM_LIMIT=<optional: 128m>

API_CPU_LIMIT=<optional: 0.50>
API_MEM_LIMIT=<optional: 256m>

WORKER_CPU_LIMIT=<optional: 0.50>
WORKER_MEM_LIMIT=<optional: 256m>

APP_CPU_LIMIT=<optional: 0.50>
APP_MEM_LIMIT=<optional: 256m>
